{
  "theme": "default",
  "themeVariables": {
    "fontSize": "20px",
    "fontFamily": "arial, helvetica, sans-serif",
    "primaryTextColor": "#1a1a1a",
    "lineColor": "#444444"
  },
  "flowchart": {
    "htmlLabels": true,
    "curve": "basis",
    "nodeSpacing": 55,
