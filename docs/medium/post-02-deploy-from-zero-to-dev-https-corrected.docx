  <w:body>
    <w:p>
      <w:pPr>
        <w:pStyle w:val="Heading1"/>
      </w:pPr>
      <w:r>
        <w:t>Medium Draft — Part 2 of 3</w:t>
      </w:r>
    </w:p>

    <w:p>
      <w:r>
        <w:rPr><w:b/></w:rPr>
        <w:t>Suggested Title:</w:t>
      </w:r>
      <w:r>
        <w:t> From Clone to HTTPS: Deploying Online Boutique on Azure (Terraform, AKS, and Your First Pipeline)</w:t>
      </w:r>
    </w:p>

    <w:p>
      <w:r>
        <w:rPr><w:b/></w:rPr>
        <w:t>Subtitle:</w:t>
      </w:r>
      <w:r>
        <w:t> Part 2 of 3 — Bootstrap state, install the platform stack, register Azure DevOps CI, and open the dev storefront</w:t>
      </w:r>
    </w:p>

    <w:p>
      <w:r>
        <w:rPr><w:b/></w:rPr>
        <w:t>Tags (pick 5):</w:t>
      </w:r>
      <w:r>
        <w:t> Azure, Kubernetes, Terraform, AKS, Helm, Argo CD, DevOps, Tutorial</w:t>
      </w:r>
    </w:p>

